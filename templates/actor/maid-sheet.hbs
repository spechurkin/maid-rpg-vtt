<form class="{{cssClass}} maid-character-sheet" autocomplete="off">
    {{#if (eq actor.type "maid")}}
        <header class="maid-sheet-header">
            <section class="maid-sheet-title">
                <h1>MAID RPG</h1>
                <h2>{{localize "MAID_RPG.Maid.CharacterSheet"}}</h2>
                <div class="maid-role-radios">
                    <label><input type="radio" checked disabled/> {{localize "MAID_RPG.Actor.Maid"}}</label>
                    <label><input type="radio" disabled/> {{localize "MAID_RPG.Actor.Butler"}}</label>
                    <label><input type="radio" disabled/> {{localize "MAID_RPG.Actor.Master"}}</label>
                </div>
            </section>

            <section class="identity-panel bordered-panel">
                <div class="grid two-col compact-grid">
                    <label class="underlined-label">{{localize "Name"}}
                        <input name="name" type="text" value="{{actor.name}}"/>
                    </label>
                    <label class="underlined-label">{{localize "MAID_RPG.Sheet.Age"}}
                        <input name="system.age" type="number" value="{{system.age}}"/>
                    </label>
                </div>
                <div class="grid three-col compact-grid">
                    <label class="underlined-label">{{localize "MAID_RPG.Maid.Color.Clothes"}}
                        <input name="system.colors.clothes" type="text" value="{{system.colors.clothes}}"/>
                    </label>
                    <label class="underlined-label">{{localize "MAID_RPG.Maid.Color.Eyes"}}
                        <input name="system.colors.eyes" type="text" value="{{system.colors.eyes}}"/>
                    </label>
                    <label class="underlined-label">{{localize "MAID_RPG.Maid.Color.Hair"}}
                        <input name="system.colors.hair" type="text" value="{{system.colors.hair}}"/>
                    </label>
                </div>
            </section>

            <section class="maid-types-panel bordered-panel">
                <label class="underlined-label">{{localize "MAID_RPG.Maid.Type"}} 1
                    <select name="system.maidTypes.0">
                        {{selectOptions config.maidTypes selected=(lookup system.maidTypes 0) localize=true blank=""}}
                    </select>
                </label>
                <label class="underlined-label">{{localize "MAID_RPG.Maid.Type"}} 2
                    <select name="system.maidTypes.1">
                        {{selectOptions config.maidTypes selected=(lookup system.maidTypes 1) localize=true blank=""}}
                    </select>
                </label>
            </section>
        </header>

        <nav class="sheet-tabs tabs maid-sheet-tabs" data-group="primary">
            <a class="item" data-tab="main">{{localize "MAID_RPG.Tab.Main"}}</a>
            <a class="item" data-tab="bio">{{localize "MAID_RPG.Tab.Bio"}}</a>
        </nav>

        <section class="sheet-body">
            <section class="tab" data-group="primary" data-tab="main">
                <main class="maid-sheet-grid">
            <aside class="attributes-panel bordered-panel">
                <div class="note-heading-strip">
                    <h3>{{localize "MAID_RPG.Sheet.Attributes"}}</h3>
                </div>
                <div class="attribute-grid">
                    {{#each system.attributes as |value key|}}
                        <div class="attribute-card">
                            <button class="attribute-roll" type="button" data-roll-attribute="{{key}}">{{localize
                                    (lookup ../config.attributes key)}}</button>
                            <output class="attribute-total">{{lookup ../system.attributeTotals key}}</output>
                            <div class="attribute-inputs">
                                <label><input type="number" name="system.attributes.{{key}}"
                                              value="{{value}}" min="0"/><span>{{localize "MAID_RPG.Sheet.Base"}}</span></label>
                                <label><input type="number" name="system.attributeMods.{{key}}"
                                              value="{{lookup ../system.attributeMods key}}" readonly/><span>{{localize
                                        "MAID_RPG.Sheet.Mod"}}</span></label>
                            </div>
                        </div>
                    {{/each}}
                </div>
                <div class="note-heading-strip">
                    <h3>{{localize "MAID_RPG.Sheet.QuickRolls"}}</h3>
                </div>
                <div class="quick-rolls grid two-col">
                    <button type="button" data-roll-formula="1d6">D6</button>
                    <button type="button" data-roll-formula="2d6">2D6</button>
                    <button type="button" data-roll-formula="1d6 * 10 + 1d6">D66</button>
                    <button type="button" data-roll-formula="1d6 * 100 + 1d6 * 10 + 1d6">D666</button>
                </div>
            </aside>

            <section class="maid-main-panel">
                <div class="grid three-col feature-row">
                    <section class="feature-box">
                        <div class="note-heading-strip">
                            <h3>{{localize "MAID_RPG.Maid.Root.Label"}}</h3>
                        </div>
                        <select name="system.root">{{selectOptions config.maidRoots selected=system.root localize=true
                                                                   blank=""}}</select>
                        <textarea name="system.rootDescription" placeholder="{{localize
                                'MAID_RPG.Maid.Root.DescriptionPlaceholder'}}">{{system.rootDescription}}</textarea>
                    </section>
                    <section class="feature-box">
                        <div class="note-heading-strip">
                            <h3>{{localize "MAID_RPG.Maid.StressExplosion.Label"}}</h3>
                        </div>
                        <select name="system.stressExplosion">{{selectOptions config.stressExplosions
                                                                              selected=system.stressExplosion
                                                                              localize=true blank=""}}</select>
                        <textarea name="system.stressExplosionDescription" placeholder="{{localize
                                'MAID_RPG.Maid.StressExplosion.DescriptionPlaceholder'}}">{{system.stressExplosionDescription}}</textarea>
                    </section>
                    <section class="feature-box">
                        <div class="note-heading-strip">
                            <h3>{{localize "MAID_RPG.Maid.MaidPower.Label"}}</h3>
                        </div>
                        <select name="system.maidPower">
                            <option value=""></option>
                            {{#select system.maidPower}}
                                {{#each config.maidPowers as |group|}}
                                    <optgroup label="{{localize group.label}}">
                                        {{#each group.options as |label value|}}
                                            <option value="{{value}}">{{localize label}}</option>
                                        {{/each}}
                                    </optgroup>
                                {{/each}}
                            {{/select}}
                        </select>
                        <textarea name="system.maidPowerDescription" placeholder="{{localize
                                'MAID_RPG.Maid.MaidPower.DescriptionPlaceholder'}}">{{system.maidPowerDescription}}</textarea>
                    </section>
                </div>

                <section class="qualities-panel">
                    <div class="note-heading-strip">
                        <h3>{{localize "MAID_RPG.Maid.SpecialQuality.Plural"}}</h3>
                    </div>
                    <div class="grid three-col feature-row">
                        <section class="feature-box">
                            <select name="system.specialQualities.0">{{selectOptions config.specialQualities
                                                                                     selected=(lookup system.specialQualities 0)
                                                                                     localize=true blank=""}}</select>
                            <textarea name="system.specialQualityDescriptions.0" placeholder="{{localize
                                    'MAID_RPG.Maid.SpecialQuality.DescriptionPlaceholder'}}">{{lookup
                                    system.specialQualityDescriptions 0}}</textarea>
                        </section>
                        <section class="feature-box">
                            <select name="system.specialQualities.1">{{selectOptions config.specialQualities
                                                                                     selected=(lookup system.specialQualities 1)
                                                                                     localize=true blank=""}}</select>
                            <textarea name="system.specialQualityDescriptions.1" placeholder="{{localize
                                    'MAID_RPG.Maid.SpecialQuality.DescriptionPlaceholder'}}">{{lookup
                                    system.specialQualityDescriptions 1}}</textarea>
                        </section>
                        <section class="feature-box">
                            <select name="system.specialQualities.2">{{selectOptions config.specialQualities
                                                                                     selected=(lookup system.specialQualities 2)
                                                                                     localize=true blank=""}}</select>
                            <textarea name="system.specialQualityDescriptions.2" placeholder="{{localize
                                    'MAID_RPG.Maid.SpecialQuality.DescriptionPlaceholder'}}">{{lookup
                                    system.specialQualityDescriptions 2}}</textarea>
                        </section>
                    </div>
                </section>
            </section>
                </main>

                <section class="maid-notes-grid">
                    <section class="note-box">
                        <div class="note-heading-strip">
                            <h3>{{localize "MAID_RPG.Stress"}}</h3>
                        </div>
                        <textarea name="system.stressNotes" placeholder="{{localize
                                'MAID_RPG.Sheet.StressPlaceholder'}}">{{system.stressNotes}}</textarea>
                    </section>
                    <section class="note-box">
                        <div class="note-heading-strip">
                            <h3>{{localize "MAID_RPG.Sheet.MaidWeapons"}}</h3>
                        </div>
                        <textarea
                                name="system.maidWeapons"
                                placeholder="{{localize 'MAID_RPG.Sheet.MaidWeapons'}}">{{system.maidWeapons}}</textarea>
                    </section>
                    <section class="note-box">
                        <div class="note-heading-strip">
                            <h3>{{localize "MAID_RPG.Favor"}}</h3>
                        </div>
                        <textarea name="system.favorNotes"
                                  placeholder="{{localize 'MAID_RPG.Sheet.FavorPlaceholder'}}">{{system.favorNotes}}</textarea>
                    </section>
                    <section class="note-box">
                        <div class="note-heading-strip">
                            <h3>{{localize "MAID_RPG.Sheet.Trauma"}}</h3>
                        </div>
                        <textarea
                                name="system.trauma"
                                placeholder="{{localize
                                        'MAID_RPG.Sheet.Trauma'}}">{{system.trauma}}</textarea>
                    </section>
                    <section class="note-box">
                        <div class="note-heading-strip">
                            <h3>{{localize "MAID_RPG.Sheet.Seduction"}}</h3>
                        </div>
                        <textarea name="system.seduction"
                                  placeholder="{{localize
                                          'MAID_RPG.Sheet.SeductionPlaceholder'}}">{{system.seduction}}</textarea>
                    </section>
                </section>
            </section>

            <section class="tab" data-group="primary" data-tab="bio">
                <section class="maid-bio-grid">
                    <section class="maid-portrait-panel note-box">
                        <div class="note-heading-strip">
                            <h3>{{localize "MAID_RPG.Sheet.Portrait"}}</h3>
                        </div>
                        <img class="maid-profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"/>
                    </section>
                    <section class="maid-backstory-panel note-box">
                        <div class="note-heading-strip">
                            <h3>{{localize "MAID_RPG.Sheet.Backstory"}}</h3>
                        </div>
                        <textarea name="system.description" placeholder="{{localize 'MAID_RPG.Sheet.BackstoryPlaceholder'}}">{{system.description}}</textarea>
                    </section>
                </section>

                <section class="maid-notes-grid">
                    <section class="note-box">
                        <div class="note-heading-strip">
                            <h3>{{localize "MAID_RPG.Notes"}}</h3>
                        </div>
                        <textarea name="system.notes"
                                  placeholder="{{localize
                                          'MAID_RPG.Sheet.NotesPlaceholder'}}">{{system.notes}}</textarea>
                    </section>
                </section>
            </section>
        </section>
    {{else}}
        <header class="sheet-header">
            <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"/>
            <div class="header-fields">
                <h1><input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'Name'}}"/></h1>
                <div class="resources grid two-col">
                    <label>{{localize "MAID_RPG.Resolve"}} <input type="number" name="system.resolve.value"
                                                                  value="{{system.resolve.value}}"/></label>
                    <label>{{localize "MAID_RPG.Stress"}} <input type="number" name="system.stress.value"
                                                                 value="{{system.stress.value}}"/></label>
                </div>
            </div>
        </header>
    {{/if}}
</form>
